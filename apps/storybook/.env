# https://vite.dev/guide/env-and-mode.html#env-files
# If you want to modify variable temporarily, please edit .env.local file

# for vite https config
# VITE_SSL_KEY_PATH=/Users/tonyyang/woo/certs/localhost+1-key.pem
# VITE_SSL_CERT_PATH=/Users/tonyyang/woo/certs/localhost+1.pem

# staging, prod
VITE_ENV=staging

# testnet, mainnet
VITE_NETWORK_ID=testnet

# custom broker id
VITE_BROKER_ID=demo

# custom brokder name
VITE_BROKER_NAME=Orderly

# add package to watch when storybook is running (comma-separated package names only; short names get @orderly.network/ prefix)
# if not set, all packages will be watched
# VITE_WATCH_PACKAGES=react-app,hooks,core,net,perp,utils,types,default-evm-adapter,default-solana-adapter,web3-provider-ethers,ui,ui-chain-selector,ui-connector,ui-leverage,ui-order-entry,ui-orders,ui-positions,ui-scaffold,ui-share,ui-tpsl,ui-tradingview,ui-transfer,ui-notification,chart,affiliate,markets,portfolio,trading,trading-leaderboard,trading-rewards,vaults,wallet-connector,wallet-connector-privy,i18n/locales,i18n

# override or add package paths (comma-separated "package=path"; package name as-is, no auto prefix)
# when path ends with /dist or /src, only that directory is watched
# when path is a package root (no /dist or /src suffix), both "<path>/dist" and "<path>/src" will be watched
# examples:
# VITE_WATCH_PACKAGE_PATHS=@orderly.network/trading-points=/Users/you/Project/js-sdk-packages/trading-points

# Restrict Storybook to display only the specified page stories (trading, portfolio, markets, affiliate, rewards, leaderboard)
# if not set, all stories will be displayed
# STORYBOOK_PAGES=trading,portfolio,markets,affiliate,rewards,leaderboard
# STORYBOOK_PAGES=plugin

# disabled storybook addons
STORYBOOK_DISABLED_ADDONS=false
